{
  "name": "real-time-spatial-tracking-gateway",
  "version": "1.0.0",
  "description": "A backend WebSocket service that securely ingests, processes, and broadcasts live geolocation coordinates.",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/"
  },
  "keywords": ["websocket", "geolocation", "gps", "tracking", "realtime"],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.7",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^11.1.0",
    "ws": "^8.18.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "vitest": "^3.1.1"
  }
}
